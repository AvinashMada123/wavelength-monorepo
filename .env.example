# ============================================================
# Wavelength — Combined Environment Variables
#
# Copy this file to .env and fill in your values.
# The frontend reads from frontend/.env.local
# The backend reads from backend/.env
# ============================================================

# ============================================================
# FRONTEND (frontend/.env.local)
# ============================================================

# Points the Next.js API proxy to the FastAPI backend.
# For local development use http://localhost:3001/call/conversational
# For production replace with your deployed backend URL.
CALL_SERVER_URL=http://localhost:3001/call/conversational

# PostgreSQL database (shared between frontend API routes and backend)
DATABASE_URL=postgresql://user:password@localhost:5432/wavelength

# Firebase — client-side keys (safe to expose)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin — server-side (keep secret)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Gemini AI — used by the frontend for lead qualification
GEMINI_API_KEY=

# Email (Gmail SMTP for invite emails)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# n8n transcript webhook (optional — post-call transcript notification)
N8N_TRANSCRIPT_WEBHOOK_URL=https://n8n.srv1100770.hstgr.cloud/webhook/fwai-transcript

# ============================================================
# BACKEND (backend/.env)
# ============================================================

# Server port — must match the port in CALL_SERVER_URL above
PORT=3001
HOST=0.0.0.0
DEBUG=false

# Call provider: "plivo", "whatsapp", or "exotel"
CALL_PROVIDER=plivo

# Plivo credentials
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_PHONE_NUMBER=+1234567890
# For local dev, use your ngrok URL: https://xxxx.ngrok.io
PLIVO_CALLBACK_URL=https://your-server.com

# Google Gemini (Gemini 2.5 Live for real-time voice)
GOOGLE_API_KEY=

# Voice for TTS
TTS_VOICE=Kore

# WhatsApp (optional — only needed if CALL_PROVIDER=whatsapp)
PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
META_VERIFY_TOKEN=my_super_secret_token_123

# Exotel (optional — only needed if CALL_PROVIDER=exotel)
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SID=
EXOTEL_CALLER_ID=
EXOTEL_APP_ID=
EXOTEL_CALLBACK_URL=
