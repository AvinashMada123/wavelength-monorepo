# ============================================================
# Backend environment variables
# Copy this file to .env and fill in your values.
# ============================================================

# ── Server ───────────────────────────────────────────────────
# IMPORTANT: Use port 3001 locally so it doesn't conflict with
# the Next.js frontend which runs on port 3000.
PORT=3001
HOST=0.0.0.0
DEBUG=false

# ── Call provider ────────────────────────────────────────────
# Options: "plivo", "whatsapp", "exotel"
CALL_PROVIDER=plivo

# ── Plivo ────────────────────────────────────────────────────
# Get credentials from: https://console.plivo.com/dashboard/
PLIVO_AUTH_ID=your_plivo_auth_id
PLIVO_AUTH_TOKEN=your_plivo_auth_token
PLIVO_PHONE_NUMBER=+1234567890
# For local dev use ngrok: https://xxxx.ngrok.io
# For production use your server URL: https://api.yourdomain.com
PLIVO_CALLBACK_URL=https://your-server.com

# ── Google Gemini (Gemini 2.5 Live for real-time voice) ──────
GOOGLE_API_KEY=your_google_api_key

# ── Voice settings ───────────────────────────────────────────
TTS_VOICE=Kore

# ── WhatsApp Business API (only needed if CALL_PROVIDER=whatsapp) ──
PHONE_NUMBER_ID=your_whatsapp_phone_number_id
META_ACCESS_TOKEN=your_facebook_meta_access_token
META_VERIFY_TOKEN=my_super_secret_token_123

# ── Exotel (only needed if CALL_PROVIDER=exotel) ─────────────
EXOTEL_API_KEY=your_exotel_api_key
EXOTEL_API_TOKEN=your_exotel_api_token
EXOTEL_SID=your_exotel_sid
EXOTEL_CALLER_ID=your_exotel_virtual_number
EXOTEL_APP_ID=your_exotel_app_id
EXOTEL_CALLBACK_URL=https://your-server.com

# ── Gemini Live Service (advanced — usually leave as default) ─
GEMINI_LIVE_HOST=localhost
GEMINI_LIVE_PORT=8003
